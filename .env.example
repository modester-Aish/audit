PORT=5055
SECRET_KEY=change-me

# Base URL to crawl (include scheme). Examples:
# BASE_URL=https://seordp.net
# BASE_URL=http://localhost:3000
BASE_URL=

# Internal portal auth (basic auth)
# Vercel: REQUIRE_AUTH defaults to off when VERCEL=1 unless you set this in Project Settings.
REQUIRE_AUTH=false
AUDIT_USERNAME=admin
AUDIT_PASSWORD=change-me

# Crawler behavior
MAX_PAGES=5000
REQUEST_TIMEOUT_SECONDS=20
USER_AGENT=SEO-Audit-Portal/1.0
CRAWL_DELAY_SECONDS=0

# Auto recrawl (minutes). 0 disables. Example: 60 => recrawl every hour
AUTO_RECRAWL_MINUTES=0

# If true, crawler will ignore robots.txt (still respects auth/content restrictions)
IGNORE_ROBOTS_TXT=true

# If true, store/parse HTML even on non-200 responses when present
TRY_PARSE_HTML_ON_ERROR=true

# Full-site crawl: seed queue from robots.txt Sitemap: + /sitemap.xml (recommended for JS sites)
USE_SITEMAP_SEED=true
SITEMAP_SEED_CAP=5000

# If true: only URLs from sitemaps + homepage seed—no extra URLs from <a href> or __NEXT_DATA__
SITEMAP_ONLY=false

# Only when VERCEL=1: max URLs per crawl (runs in one HTTP request; match your plan’s function max duration)
VERCEL_MAX_PAGES=5000
